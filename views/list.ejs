<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>todo list</title>
    <link rel="stylesheet" href="/navbar.css">
    <link rel="stylesheet" href="/todoList.css">
</head>

<body>
    <%- include('navbar') %>
        <h2>Task List Page</h2>
        <form  action="/delete-items" method="POST">
        
            <button type="submit" class="delete-btn">Delete selected tasks</button>
       
        <div class="task-list">
            <% tasks.forEach(task=> { %>
                <div class="task-card">
                    <div class="task-header">
                        <input type="checkbox" name="selectedTasks" value="<%= task._id %>" class="task-check" id="<%= task._id %>" />
                        <label for="<%= task._id %>">
                            <h3>
                                <%= task.title %>
                            </h3>
                            <p>
                                <%= task.description %>
                            </p>
                        </label>
                    </div>
                    <div class="btn-group">
                        <a href="/delete/<%= task._id %>">
                            <button class="delete-btn">Delete</button>
                        </a>
                        <a href="/update/<%= task._id %>">
                            <button class="update-btn">Update</button>
                        </a>
                    </div>
                </div>
                <% }) %>
        </div>
        </form >
</body>

</html>